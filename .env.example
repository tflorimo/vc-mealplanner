# ============================================================
# VC Meal Planner - Variables de Entorno
# Copiá este archivo a .env y completá los valores.
# NUNCA commitear el archivo .env real.
#
# Docker: docker-compose.yml lee este .env automáticamente.
#   - DB_HOST es ignorado en Docker (se usa el service name 'mysql' hardcodeado)
#   - DB_PASSWORD y DB_NAME son usados por MySQL y el backend
# ============================================================

# --- Base de Datos MySQL ---
DB_HOST=localhost       # local: localhost | Docker: ignorado (usa 'mysql')
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_NAME=vc_mealplanner

# --- Servidor Backend ---
PORT=3001

# --- Frontend (para CORS en backend) ---
FRONTEND_URL=http://localhost:5173
